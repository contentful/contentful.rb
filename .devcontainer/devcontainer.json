{
  "name": "contentful.rb",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "RUBY_VERSION": "${localEnv:RUBY_VERSION:3.4}"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "postCreateCommand": "bundle install",
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp"
      ]
    }
  }
}
